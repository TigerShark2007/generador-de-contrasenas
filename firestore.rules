rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // User Profile Rules
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && 
        request.resource.data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt']) &&
        request.resource.data.uid == uid;
      allow update: if isOwner(uid) && 
        request.resource.data.uid == uid &&
        request.resource.data.email == resource.data.email;
    }

    // Password History Rules
    match /users/{uid}/passwords/{passwordId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && 
        request.resource.data.keys().hasAll(['uid', 'password', 'entropy', 'score', 'timestamp']) &&
        request.resource.data.uid == uid &&
        request.resource.data.password is string &&
        request.resource.data.password.size() <= 128 &&
        request.resource.data.entropy is number &&
        request.resource.data.score is number;
      allow update: if isOwner(uid) && 
        request.resource.data.uid == uid;
      allow delete: if isOwner(uid);
    }
  }
}
